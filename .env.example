# LSD LLM provider configuration — TEMPLATE.
#
# Copy to `.env` (which is gitignored) and fill in real values there:
#     cp .env.example .env
# NEVER put real keys in this file or commit a filled-in `.env`.
#
# LSD reads these at runtime via os.environ (see src/lsd/llm/__init__.py). The key
# is held in memory and sent only as an auth header to the endpoint you configure
# below — it is never written to a generated package, metadata.json, or logs.
#
# Load the file into your shell for a run, e.g.:
#     set -a; source .env; set +a
#     lsd build <url>
# or use direnv / your secrets manager. Prefer a per-project key with a spend cap.

# --- Option A: Anthropic ---------------------------------------------------
LSD_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
LSD_MODEL=claude-haiku-3-5

# --- Option B: OpenAI-compatible endpoint (OpenAI, OpenRouter, Inception, Ollama…) ---
# Only point LSD_LLM_BASE_URL at a provider you trust — your key is sent to that host.
# LSD_LLM_PROVIDER=openai-compat
# LSD_LLM_BASE_URL=https://api.openai.com/v1
# LSD_LLM_API_KEY=REPLACE_ME
# LSD_MODEL=gpt-4o-mini
# LSD_OMIT_MAX_TOKENS=1        # set for providers that reject max_tokens (e.g. Inception dLLM)
